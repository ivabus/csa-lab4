use std::io::{read, write, read_num, print, println};

const PORT_OUT: u32 = 0x0004;

fn rotr(x: u32, n: u32) -> u32 {
    return (x >> n) | (x << (32 - n));
}

fn print_hex_u32(val: u32) {
    let mut i = 0;
    while i < 8 {
        let shift = 28 - (i * 4);
        let nibble = (val >> shift) & 0xF;
        if nibble < 10 {
            *PORT_OUT = nibble + '0';
        } else {
            *PORT_OUT = nibble - 10 + 'a';
        }
        i += 1;
    }
}

fn init_k_0(k: u32) {
    k[0] = 0x428a2f98; k[1] = 0x71374491; k[2] = 0xb5c0fbcf; k[3] = 0xe9b5dba5;
    k[4] = 0x3956c25b; k[5] = 0x59f111f1; k[6] = 0x923f82a4; k[7] = 0xab1c5ed5;
    k[8] = 0xd807aa98; k[9] = 0x12835b01; k[10]= 0x243185be; k[11]= 0x550c7dc3;
    k[12]= 0x72be5d74; k[13]= 0x80deb1fe; k[14]= 0x9bdc06a7; k[15]= 0xc19bf174;
}
fn init_k_1(k: u32) {
    k[16]= 0xe49b69c1; k[17]= 0xefbe4786; k[18]= 0x0fc19dc6; k[19]= 0x240ca1cc;
    k[20]= 0x2de92c6f; k[21]= 0x4a7484aa; k[22]= 0x5cb0a9dc; k[23]= 0x76f988da;
    k[24]= 0x983e5152; k[25]= 0xa831c66d; k[26]= 0xb00327c8; k[27]= 0xbf597fc7;
    k[28]= 0xc6e00bf3; k[29]= 0xd5a79147; k[30]= 0x06ca6351; k[31]= 0x14292967;
}
fn init_k_2(k: u32) {
    k[32]= 0x27b70a85; k[33]= 0x2e1b2138; k[34]= 0x4d2c6dfc; k[35]= 0x53380d13;
    k[36]= 0x650a7354; k[37]= 0x766a0abb; k[38]= 0x81c2c92e; k[39]= 0x92722c85;
    k[40]= 0xa2bfe8a1; k[41]= 0xa81a664b; k[42]= 0xc24b8b70; k[43]= 0xc76c51a3;
    k[44]= 0xd192e819; k[45]= 0xd6990624; k[46]= 0xf40e3585; k[47]= 0x106aa070;
}
fn init_k_3(k: u32) {
    k[48]= 0x19a4c116; k[49]= 0x1e376c08; k[50]= 0x2748774c; k[51]= 0x34b0bcb5;
    k[52]= 0x391c0cb3; k[53]= 0x4ed8aa4a; k[54]= 0x5b9cca4f; k[55]= 0x682e6ff3;
    k[56]= 0x748f82ee; k[57]= 0x78a5636f; k[58]= 0x84c87814; k[59]= 0x8cc70208;
    k[60]= 0x90befffa; k[61]= 0xa4506ceb; k[62]= 0xbef9a3f7; k[63]= 0xc67178f2;
}

fn init_k(k: u32) {
    init_k_0(k); init_k_1(k); init_k_2(k); init_k_3(k);
}

fn prepare_w(w: u32) {
    let mut i = 16;
    while i < 64 {
        let v15: u32 = w[i - 15];
        let v2: u32 = w[i - 2];
        let v16: u32 = w[i - 16];
        let v7: u32 = w[i - 7];
        let s0 = rotr(v15, 7) ^ rotr(v15, 18) ^ (v15 >> 3);
        let s1 = rotr(v2, 17) ^ rotr(v2, 19) ^ (v2 >> 10);
        w[i] = v16 + s0 + v7 + s1;
        i += 1;
    }
}

fn compress(h: u32, w: u32, k: u32) {
    let mut a: u32 = h[0];
    let mut b: u32 = h[1];
    let mut c: u32 = h[2];
    let mut d: u32 = h[3];
    let mut e: u32 = h[4];
    let mut f: u32 = h[5];
    let mut g: u32 = h[6];
    let mut hv: u32 = h[7];
    let mut i = 0;
    while i < 64 {
        let s1 = rotr(e, 6) ^ rotr(e, 11) ^ rotr(e, 25);
        let ch = (e & f) ^ ((~e) & g);
        let ki: u32 = k[i];
        let wi: u32 = w[i];
        let t1 = hv + s1 + ch + ki + wi;
        let s0 = rotr(a, 2) ^ rotr(a, 13) ^ rotr(a, 22);
        let maj = (a & b) ^ (a & c) ^ (b & c);
        let t2 = s0 + maj;
        hv = g; g = f; f = e; e = d + t1; d = c; c = b; b = a; a = t1 + t2;
        i += 1;
    }
    h[0] += a; h[1] += b; h[2] += c; h[3] += d;
    h[4] += e; h[5] += f; h[6] += g; h[7] += hv;
}

fn fill_w_from_block(w: u32, b: cstr) {
    let mut i = 0;
    while i < 16 {
        let j = i * 4;
        let b1: u32 = b[j];
        let b2: u32 = b[j+1];
        let b3: u32 = b[j+2];
        let b4: u32 = b[j+3];
        w[i] = (b1 << 24) | (b2 << 16) | (b3 << 8) | b4;
        i += 1;
    }
}

fn main() {
    let k = reserve::<u32>(64);
    init_k(k);
    let h = reserve::<u32>(8);
    h[0] = 0x6a09e667; h[1] = 0xbb67ae85; h[2] = 0x3c6ef372; h[3] = 0xa54ff53a;
    h[4] = 0x510e527f; h[5] = 0x9b05688c; h[6] = 0x1f83d9ab; h[7] = 0x5be0cd19;
    let w = reserve::<u32>(64);
    let block: cstr = reserve::<u8>(64);
    let total_len: u32 = read_num();
    let mut rem = total_len;
    while rem >= 64 {
        let mut i = 0;
        while i < 64 { block[i] = read(); i += 1; }
        fill_w_from_block(w, block);
        prepare_w(w);
        compress(h, w, k);
        rem -= 64;
    }
    let mut i_rem = 0;
    while i_rem < rem { block[i_rem] = read(); i_rem += 1; }
    block[i_rem] = 0x80; i_rem += 1;
    if i_rem > 56 {
        while i_rem < 64 { block[i_rem] = 0; i_rem += 1; }
        fill_w_from_block(w, block);
        prepare_w(w);
        compress(h, w, k);
        i_rem = 0;
    }
    while i_rem < 56 { block[i_rem] = 0; i_rem += 1; }
    let bits_low = total_len << 3;
    let bits_high = total_len >> 29;
    block[56] = bits_high >> 24; block[57] = bits_high >> 16; block[58] = bits_high >> 8; block[59] = bits_high;
    block[60] = bits_low >> 24; block[61] = bits_low >> 16; block[62] = bits_low >> 8; block[63] = bits_low;
    fill_w_from_block(w, block);
    prepare_w(w);
    compress(h, w, k);
    let mut j = 0;
    while j < 8 {
        print_hex_u32(h[j]);
        j += 1;
    }
}